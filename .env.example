# RAC defaults are intentionally conservative.
RAC_ENV=dev
RAC_TRADING_MODE=paper
RAC_LIVE_TRADING_ENABLED=false
RAC_BROKER=auto

# Alpaca paper credentials. Never commit real values.
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Live credentials must remain unset for MVP.
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
LIVE_UNLOCK_TOKEN=

# Local AI. Ollama is the only supported AI runtime.
OLLAMA_BASE_URL=http://host.docker.internal:11434
RAC_AI_ENABLED=auto
RAC_EMBEDDINGS_ENABLED=auto

# Storage and eventing.
DATABASE_URL=postgresql+psycopg://rac:rac@postgres:5432/rac
REDIS_URL=redis://redis:6379/0
EVENT_BUS_URL=redpanda:9092

# Observability.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Risk limits for paper MVP. Tune only through reviewed config.
RAC_MAX_DAILY_LOSS_PCT=1.0
RAC_MAX_WEEKLY_LOSS_PCT=3.0
RAC_MAX_POSITION_PCT=5.0
RAC_MAX_ASSET_EXPOSURE_PCT=10.0
RAC_MAX_DRAWDOWN_PCT=5.0
RAC_COOLDOWN_AFTER_LOSSES=3

# Worker loop configuration.
RAC_SYMBOLS=AAPL,MSFT,SPY
RAC_TIMEFRAME=1Min
RAC_LOOP_INTERVAL=60
ALPACA_DATA_BASE_URL=https://data.alpaca.markets/v2
